# Copy this file to phase0/.env and edit local-only values there.
# Real phase0/.env is intentionally ignored by git.

GLOSS_LOG_FORMAT=plain

# Local-only values and machine-specific paths. Shared defaults such as run_id,
# active profile, runs, max_tokens, base_url, and output_dir live in
# phase0/config.example.json and phase0/model-profiles.json.
GLOSS_PHASE0_API_KEY=local

GLOSS_PHASE0_NPURUN_PATH=.tools/npurun/npurun.exe
GLOSS_PHASE0_QNN_RUNTIME_DIR=.venv-arm64/Lib/site-packages/onnxruntime_qnn
GLOSS_PHASE0_MODELS_DIR=.models/npurun

# Optional overrides. Uncomment only when this machine needs to differ from
# shared config/profile values.
# GLOSS_PHASE0_CONFIG=phase0/config.example.json
# GLOSS_PHASE0_MODEL_PROFILES_PATH=phase0/model-profiles.json
# GLOSS_PHASE0_ACTIVE_MODEL_PROFILE=qwen3-4b
# GLOSS_PHASE0_MODEL=qwen3-4b-instruct-2507
# GLOSS_PHASE0_BASE_URL=http://127.0.0.1:11435/v1
# GLOSS_PHASE0_OUTPUT_DIR=phase0/runs/2026-06-09-xplus/npurun
# GLOSS_PHASE0_OUTPUT_FILE=openai-qwen3-4b.jsonl
# GLOSS_PHASE0_RUNS=3
# GLOSS_PHASE0_MAX_TOKENS=128
# GLOSS_PHASE0_TIMEOUT=120
# GLOSS_PHASE0_CHARS_PER_TOKEN=3.0
# GLOSS_PHASE0_SAMPLE_SECONDS=5
